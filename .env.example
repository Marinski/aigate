# ── Core ─────────────────────────────────────────────────────────────────────

# Aigate master token — single bearer that authenticates against every
# aigate-owned service: LiteLLM, claudebox, pibox-zai, predictalot, mcp,
# stealthy-auto-browse, hybrids3, telethon. Each per-service token below
# (CLAUDEBOX_API_TOKEN, PREDICTALOT_AUTH_TOKEN, etc.) defaults to this
# value when unset, so leaving them commented = one token rules them all.
# Override per-service if you want different scoped tokens per service.
AIGATE_TOKEN=change-me-aigate-master-token

# LiteLLM bearer key. Defaults to AIGATE_TOKEN when unset.
# LITELLM_MASTER_KEY=sk-...

POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://litellm:change-me-strong-password@postgres:5432/litellm

REDIS_PASSWORD=change-me-redis-password

LITELLM_WORKERS=4

# LiteLLM Admin UI (/ui/, rate limited at 30r/m)
# LITELLM_UI_BASIC_AUTH: nginx basic auth (optional, leave empty to disable)
# LITELLM_USERNAME/PASSWORD: LiteLLM's own UI login
LITELLM_UI_BASIC_AUTH=admin:change-me-password
LITELLM_USERNAME=admin
LITELLM_PASSWORD=change-me-ui-password

# ── What's enabled ────────────────────────────────────────────────────────────
# Set to 1 to enable. Credentials must also be filled in below.
# Disabled providers are excluded from the model list and fallback chains.

# Claude Code via OAuth/API key
CLAUDEBOX=
# pi-coding-agent via z.ai (GLM models)
PIBOX_ZAI=
# Groq (free tier)
GROQ=
# Cerebras (free tier)
CEREBRAS=
# OpenRouter (free tier)
OPENROUTER=
# HuggingFace (free tier)
HUGGINGFACE=
# Mistral AI (free tier)
MISTRAL=
# Cohere (trial)
COHERE=
# Anthropic (pay-per-token)
ANTHROPIC=
# OpenAI (pay-per-token)
OPENAI=
# Local CPU image generation — sd.cpp (sd-turbo, sdxl-turbo)
SDCPP=
# Local CUDA image generation — sd.cpp (FLUX, SDXL Lightning, Juggernaut XI + CPU models)
SDCPP_CUDA=
# Local CPU inference (~6GB+ RAM)
OLLAMA=
# Local CUDA inference (NVIDIA, requires nvidia-container-toolkit)
OLLAMA_CUDA=
# Talkies — unified OpenAI-compatible speech service (CPU): both
# /v1/audio/transcriptions (whisper + canary-180m) and /v1/audio/speech
# (Kokoro-82M TTS) in one container.
# External image: psyb0t/talkies (github.com/psyb0t/docker-talkies).
TALKIES=
# Talkies CUDA — adds parakeet + canary-1b + canary-qwen-2.5b ASR plus
# Qwen3-TTS-0.6B voice cloning (drop reference .wav files into
# ${DATA_DIR_TALKIES}/custom-voices/ to make them selectable as
# `voice=<filename-without-ext>` on /v1/audio/speech).
TALKIES_CUDA=
# vLLM CPU — supervised `vllm serve` subprocess proxy for OpenAI-compat
# /v1/chat/completions + /v1/completions + /v1/embeddings. Lazy-loads one
# model at a time; idle-unloads after VLLM_MODEL_TTL. Same wrapper as
# vLLM CUDA — ships Nomic Embed v2 + Qwen3-0.6B; edit vllm/models.cpu.json
# to add more. Slower than ollama for small models — use mostly for
# wrapper-API symmetry with the CUDA variant.
VLLM=
# vLLM CUDA — same wrapper, NVIDIA GPU. Faster. Ships Nomic Embed v2
# (embeddings) and Qwen3-0.6B (chat). Edit vllm/models.cuda.json
# to add more. Both VLLM and VLLM_CUDA can be enabled simultaneously
# — they share the same weight store under ${DATA_DIR_VLLM}/models/.
VLLM_CUDA=
# Stealth browser cluster (~1.3GB RAM)
BROWSER=
# Object storage + MCP
HYBRIDS3=
# Cloudflare Tunnel (public exposure)
CLOUDFLARED=
# LibreChat web UI (/librechat/)
LIBRECHAT=
# SearXNG self-hosted search engine (/searxng/) + MCP search_web tool
SEARXNG=
# Telegram client via Telethon (MCP tools + REST API at /telethon/)
TELETHON=
# Tailscale — tailnet-only HTTP proxy to aigate's nginx (no public exposure)
TAILSCALE=
# predictalot — foundation time-series forecasters (CPU, /predictalot/* + MCP)
PREDICTALOT=
# predictalot CUDA — same wrapper on NVIDIA GPU. Runs SIDE-BY-SIDE with the
# CPU variant — distinct nginx routes (`/predictalot/` vs
# `/predictalot-cuda/`) and distinct compose service-name aliases. Both
# share ${DATA_DIR_PREDICTALOT}/models (no duplicate HF snapshot downloads).
PREDICTALOT_CUDA=
# audiolla — self-hosted audio-production REST + MCP. Stem separation,
# restoration, mastering, MIR analysis, DSP transforms, loudness, speech
# enhancement, diarization, MIDI transcription + composition, curated
# workflow presets + ad-hoc pipelines (Demucs, matchering, librosa, UVR,
# basic-pitch, DeepFilterNet, pyannote, CLAP, fluidsynth, sox + ffmpeg).
# /audiolla/* + MCP at /audiolla/v1/mcp.
# Upstream: github.com/psyb0t/docker-audiolla
AUDIOLLA=
# audiolla CUDA — same wrapper on NVIDIA GPU (faster on Demucs / UVR /
# pyannote / basic-pitch / DeepFilterNet / CLAP). Runs SIDE-BY-SIDE with
# the CPU variant — distinct network aliases (`audiolla` vs `audiolla-cuda`)
# and distinct nginx routes (`/audiolla/` vs `/audiolla-cuda/`). Both share
# ${DATA_DIR_AUDIOLLA} (no duplicate weight downloads).
AUDIOLLA_CUDA=
# mailbox — IMAP+SMTP gateway REST API + MCP (/mailbox/*), needs MAILBOX_CONFIG
MAILBOX=

# ── Credentials ───────────────────────────────────────────────────────────────

# claudebox — OAuth: claude setup-token (Pro/Max/Team sub)
# CLAUDEBOX_API_TOKEN defaults to AIGATE_TOKEN. Override to scope separately.
# CLAUDEBOX_API_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=
# or API key: https://console.anthropic.com/settings/keys
# CLAUDEBOX_ANTHROPIC_API_KEY=

# pibox-zai — https://z.ai
# PIBOX_ZAI_API_TOKEN defaults to AIGATE_TOKEN. Override to scope separately.
# PIBOX_ZAI_API_TOKEN=
PIBOX_ZAI_AUTH_TOKEN=
# PIBOX_ZAI_AVAILABLE_MODELS=glm-4.5-air,glm-4.7,glm-5.1
# PIBOX_ZAI_DEFAULT_MODEL=glm-4.7

# predictalot — bearer token for /predictalot/* + MCP. No external creds needed
# (models auto-download from HuggingFace on first use).
# PREDICTALOT_AUTH_TOKEN defaults to AIGATE_TOKEN. Override to scope separately.
# PREDICTALOT_AUTH_TOKEN=
# auto / cpu / cuda / cuda:N
# PREDICTALOT_DEVICE=auto
# Comma-separated slugs to prefetch weights at container start (or "all")
# PREDICTALOT_PREFETCH=
# Comma-separated slugs to keep loaded in memory at boot
# PREDICTALOT_PRELOAD=
# Idle time before a loaded model is unloaded (Go-style: 30m, 1h, 0=disable)
# PREDICTALOT_MODEL_IDLE_TIMEOUT=30m
# Cap on request body (32mb default)
# PREDICTALOT_MAX_BODY_SIZE=32mb
# PREDICTALOT_LOG_LEVEL=INFO

# audiolla — bearer token for /audiolla/* + MCP. No external creds needed
# unless using pyannote diarization (set HF_TOKEN + accept model terms at
# huggingface.co/pyannote/speaker-diarization-3.1).
# AUDIOLLA_AUTH_TOKEN defaults to AIGATE_TOKEN. Override to scope separately.
# AUDIOLLA_AUTH_TOKEN=
# auto / cpu / cuda / cuda:N
# AUDIOLLA_DEVICE=auto
# Comma-separated engine slugs to allow (empty = all). Example:
# AUDIOLLA_ENABLED_ENGINES=htdemucs,librosa-analyze,basic-pitch
# Comma-separated slugs to keep loaded at boot
# AUDIOLLA_PRELOAD=
# Idle time before a loaded engine is unloaded (Go-style: 10m, 1h, 0=disable)
# AUDIOLLA_ENGINE_TTL=10m
# AUDIOLLA_SWEEPER_INTERVAL=60
# Upload cap (also caps URL fetch body) — bytes
# AUDIOLLA_MAX_UPLOAD_BYTES=209715200
# Server-side fetch policy for file_url / output_url:
#   disabled | allowlist | denylist
# AUDIOLLA_FETCH_MODE=disabled
# Required if mode=allowlist — comma-separated host patterns
# AUDIOLLA_FETCH_HOSTS=
# Allowed URL schemes
# AUDIOLLA_FETCH_SCHEMES=https
# Allow URLs that resolve to private/loopback IPs
# AUDIOLLA_FETCH_ALLOW_PRIVATE=false
# AUDIOLLA_FETCH_TIMEOUT=30
# Async job lifetime + concurrency
# AUDIOLLA_JOB_TTL=1h
# AUDIOLLA_JOB_MAX_CONCURRENT=8

# Groq — https://console.groq.com
GROQ_API_KEY=gsk_...

# Cerebras — https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# HuggingFace — https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Mistral — https://console.mistral.ai
MISTRAL_API_KEY=...

# Cohere — https://dashboard.cohere.com
COHERE_API_KEY=...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Service config ────────────────────────────────────────────────────────────

# Browser cluster
# STEALTHY_AUTO_BROWSE_AUTH_TOKEN defaults to AIGATE_TOKEN. Override to scope separately.
# STEALTHY_AUTO_BROWSE_AUTH_TOKEN=
STEALTHY_AUTO_BROWSE_REDIS_PASSWORD=change-me-browser-redis
STEALTHY_AUTO_BROWSE_NUM_REPLICAS=5
STEALTHY_AUTO_BROWSE_QUEUE_TIMEOUT=300

# HybridS3
# HYBRIDS3_MASTER_KEY defaults to AIGATE_TOKEN. Override to scope separately.
# HYBRIDS3_MASTER_KEY=
HYBRIDS3_UPLOADS_KEY=change-me-uploads-key
HYBRIDS3_UPLOADS_TTL=168h
HYBRIDS3_UPLOADS_MAX_SIZE=100MB

# MCP tools (image generation + TTS)
# MCP_TOOLS_AUTH_TOKEN defaults to AIGATE_TOKEN. Override to scope separately.
# MCP_TOOLS_AUTH_TOKEN=

# LibreChat
# encryption key for stored credentials (generate once, don't change)
LIBRECHAT_CREDS_KEY=change-me-64-hex-chars
# encryption IV (generate once, don't change)
LIBRECHAT_CREDS_IV=change-me-32-hex-chars
# JWT signing secret
LIBRECHAT_JWT_SECRET=change-me-jwt-secret
# public URL where LibreChat is accessed
LIBRECHAT_DOMAIN_CLIENT=https://your-domain.com/librechat
LIBRECHAT_DOMAIN_SERVER=https://your-domain.com/librechat
# model used for auto-titling conversations (must exist in LiteLLM)
LIBRECHAT_TITLE_MODEL=groq-llama-3.3-70b
# LIBRECHAT_DEBUG_LOGGING=true
# LIBRECHAT_DEBUG_CONSOLE=false
# LIBRECHAT_ALLOW_EMAIL_LOGIN=true
# first registered user becomes admin automatically
# set to false after creating your admin account
LIBRECHAT_ALLOW_REGISTRATION=true
# LIBRECHAT_ALLOW_SOCIAL_LOGIN=false
# LIBRECHAT_ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# Telethon — Telegram client (get creds: https://my.telegram.org/apps, session: docker run psyb0t/telethon login)
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=
# TELETHON_AUTH_KEY defaults to AIGATE_TOKEN. Override to scope separately.
# TELETHON_AUTH_KEY=
# TELETHON_PROXY=socks5://user:pass@host:port
# TELETHON_LOG_LEVEL=INFO

# mailbox — IMAP+SMTP gateway. Config holds plaintext IMAP/SMTP passwords + the
# bearer tokens that gate the API. Keep the file outside the repo (or gitignored)
# and mirror MAILBOX_AUTH_TOKEN into its auth.tokens list. Schema: see
# .research_files/docker-mailbox/config.example.yaml or upstream README.
# MAILBOX_CONFIG: absolute or repo-relative path to the YAML config on the host.
MAILBOX_CONFIG=
# MAILBOX_AUTH_TOKEN: must also appear in MAILBOX_CONFIG's auth.tokens: [...]
MAILBOX_AUTH_TOKEN=change-me-mailbox-auth
# Optional — enables the test_mailbox_send_recv_delete e2e test. The test sends
# real mail to MAILBOX_TEST_ADDRESS via mailbox MAILBOX_TEST_MAILBOX_NAME (must
# have BOTH IMAP and SMTP configured), then polls IMAP, reads, and deletes it.
# Set the address to one you control (typically the same account's own from_address).
# Leave both empty to skip.
# MAILBOX_TEST_MAILBOX_NAME=
# MAILBOX_TEST_ADDRESS=

# Tailscale — get an auth key: https://login.tailscale.com/admin/settings/keys
# Uses tailscale serve TCPForward mode — pure L4 forwarding to nginx:4000, no Host-header matching,
# so you don't have to configure your tailnet FQDN here. Magic DNS routes <TS_HOSTNAME>.<tailnet>:80
# straight to nginx, which handles all path/host logic itself.
# TS_AUTHKEY: ephemeral or reusable auth key (tskey-auth-... for Tailscale, hskey-auth-... for Headscale).
#             Required on first run. After auth state is persisted to .data/tailscale, can be empty.
# TS_HOSTNAME: machine name on the tailnet (default: aigate)
# TS_SERVE_PORT: tailnet-side port (default: 80). Forwarded as-is to nginx:4000.
# TS_EXTRA_ARGS: extra `tailscale up` args. For Headscale, set the login server here:
#                --login-server=https://your-headscale.example.com
TS_AUTHKEY=
TS_HOSTNAME=aigate
# TS_SERVE_PORT=80
# TS_EXTRA_ARGS=

# Rate limits (nginx) — format: Nr/m or Nr/s
# admin UI (/ui, /login)
# RATELIMIT_ADMIN=30r/m
# RATELIMIT_ADMIN_BURST=20
# LiteLLM API (/)
# RATELIMIT_API=500r/m
# RATELIMIT_API_BURST=30
# hybrids3 (/storage)
# RATELIMIT_STORAGE=60r/m
# RATELIMIT_STORAGE_BURST=20
# claudebox + pibox-zai (/claudebox/, /pibox-zai/)
# RATELIMIT_CLAUDEBOX=30r/m
# RATELIMIT_CLAUDEBOX_BURST=10
# browser cluster (/stealthy-auto-browse/)
# RATELIMIT_BROWSER=30r/m
# RATELIMIT_BROWSER_BURST=10
# proxq async queue (/q/)
# RATELIMIT_PROXQ=600r/m
# RATELIMIT_PROXQ_BURST=30
# librechat web UI (/librechat/)
# RATELIMIT_LIBRECHAT=500r/m
# RATELIMIT_LIBRECHAT_BURST=100
# searxng (/searxng/)
# RATELIMIT_SEARXNG=60r/m
# RATELIMIT_SEARXNG_BURST=20
# telethon (/telethon/)
# RATELIMIT_TELETHON=30r/m
# RATELIMIT_TELETHON_BURST=10
# predictalot (/predictalot/)
# RATELIMIT_PREDICTALOT=60r/m
# RATELIMIT_PREDICTALOT_BURST=20
# predictalot CUDA (/predictalot-cuda/)
# RATELIMIT_PREDICTALOT_CUDA=60r/m
# RATELIMIT_PREDICTALOT_CUDA_BURST=20
# audiolla (/audiolla/)
# RATELIMIT_AUDIOLLA=30r/m
# RATELIMIT_AUDIOLLA_BURST=20
# audiolla CUDA (/audiolla-cuda/)
# RATELIMIT_AUDIOLLA_CUDA=30r/m
# RATELIMIT_AUDIOLLA_CUDA_BURST=20
# mailbox (/mailbox/)
# RATELIMIT_MAILBOX=60r/m
# RATELIMIT_MAILBOX_BURST=20

# Nginx timeouts (proxy_read_timeout / proxy_send_timeout)
# max upload size
# NGINX_MAX_BODY_SIZE=50m
# admin UI (/ui, /login)
# TIMEOUT_ADMIN=60s
# LiteLLM API (/) — covers all model inference (chat, audio, images,
# embeddings). Long transcriptions on CPU can take hours; long context
# completions can take minutes. Default ~unbounded.
# TIMEOUT_API=24h
# claudebox + pibox-zai (/claudebox/, /pibox-zai/) — LLM agent runs can be
# very long; default unbounded.
# TIMEOUT_CLAUDEBOX=24h
# browser cluster (/stealthy-auto-browse/)
# TIMEOUT_BROWSER=600s
# proxq submit (/q/) — fast, just enqueues
# TIMEOUT_PROXQ=30s
# librechat web UI (/librechat/) — proxies LLM completions; default unbounded.
# TIMEOUT_LIBRECHAT=24h
# searxng (/searxng/)
# TIMEOUT_SEARXNG=30s
# telethon (/telethon/)
# TIMEOUT_TELETHON=60s
# predictalot (/predictalot/) — cold model loads + long-horizon forecasts;
# default unbounded.
# TIMEOUT_PREDICTALOT=24h
# audiolla (/audiolla/) — long-running audio jobs (Demucs separation,
# pyannote diarization, full-track mastering). Default unbounded.
# TIMEOUT_AUDIOLLA=24h
# mailbox (/mailbox/)
# TIMEOUT_MAILBOX=120s

# Proxq — async job queue at /q/ (always on)
# worker concurrency
# PROXQ_CONCURRENCY=10
# how long completed jobs stay in Redis
# PROXQ_TASK_RETENTION=1h
# max time to wait for LiteLLM response
# PROXQ_UPSTREAM_TIMEOUT=30m
# retry failed upstream calls (0 = no retries)
# PROXQ_MAX_RETRIES=0
# delay between retries (0 = exponential backoff)
# PROXQ_RETRY_DELAY=30s
# max request body for queued requests (10MB)
# PROXQ_MAX_BODY_SIZE=10485760
# bodies larger than this bypass queue (10MB)
# PROXQ_DIRECT_PROXY_THRESHOLD=10485760
# none, memory, redis — cache upstream responses
# PROXQ_CACHE_MODE=none
# how long cached responses stay fresh
# PROXQ_CACHE_TTL=5m
# max entries for in-memory LRU cache
# PROXQ_CACHE_MAX_ENTRIES=10000

# Data directories — all service data lives under DATA_DIR by default.
# Override per-service to spread across disks/NAS mounts.
# base data directory (default: .data)
# DATA_DIR=.data
# default: ${DATA_DIR}/nginx
# DATA_DIR_NGINX=
# default: ${DATA_DIR}/redis
# DATA_DIR_REDIS=
# default: ${DATA_DIR}/postgres
# DATA_DIR_POSTGRES=
# default: ${DATA_DIR}/claudebox
# DATA_DIR_CLAUDEBOX=
# default: ${DATA_DIR}/pibox-zai
# DATA_DIR_PIBOX_ZAI=
# default: ${DATA_DIR}/hybrids3
# DATA_DIR_HYBRIDS3=
# default: ${DATA_DIR}/stealthy-auto-browse-redis
# DATA_DIR_BROWSER_REDIS=
# default: ${DATA_DIR}/ollama (shared by both CPU and GPU ollama)
# DATA_DIR_OLLAMA=
# default: ${DATA_DIR}/sdcpp (FLUX models, ~16GB)
# DATA_DIR_SDCPP=
# default: ${DATA_DIR}/librechat
# DATA_DIR_LIBRECHAT=
# default: ${DATA_DIR}/tailscale
# DATA_DIR_TAILSCALE=
# default: ${DATA_DIR}/predictalot (HF model snapshots, ~1.4GB for all five)
# DATA_DIR_PREDICTALOT=
# default: ${DATA_DIR}/audiolla — Demucs weights (~6GB) + UVR models +
# torch hub + staged files. Bind-mounted as /data in both the audiolla
# and audiolla-cuda containers (shared cache, no duplicate downloads).
# DATA_DIR_AUDIOLLA=
# default: ${DATA_DIR}/talkies — bind-mounted as /data inside the talkies
# container. Holds two subtrees: `hf/hub/models--*/` (HF cache, shared by
# CPU + GPU talkies) and `custom-voices/<name>.wav` (Qwen3-TTS reference
# voices, CUDA only — drop 10-30s of clean speech and use as `voice=<name>`
# on /v1/audio/speech; nested paths supported).
# DATA_DIR_TALKIES=
# default: ${DATA_DIR}/vllm — model store for the vllm-cuda wrapper.
# Holds the flat HF-repo layout under `models/<org>/<repo>/<files>`
# (no blobs/snapshots dedup) so other services can bind-mount the same
# path and load weights directly. Default: Nomic embed v2 + Qwen3-0.6B,
# extend by editing vllm/models.json.
# DATA_DIR_VLLM=

# sd.cpp tuning (defaults are fine for most setups)
# SDCPP_IDLE_TIMEOUT=5m
# SDCPP_CUDA_IDLE_TIMEOUT=5m
# SDCPP_LOAD_TIMEOUT=10m
# SDCPP_CUDA_LOAD_TIMEOUT=10m
# SDCPP_VERBOSE=false
# SDCPP_CUDA_VERBOSE=false
# SDCPP_LOG_LEVEL=info
# SDCPP_CUDA_LOG_LEVEL=info

# talkies tuning — idle TTL (-1 disables auto-unload), sweeper interval, max
# upload bytes for /v1/audio/transcriptions. Plus VAD knobs. VAD_CHUNK_THRESHOLD
# is the audio-length cutoff (seconds) above which the wrapper VAD-chunks input;
# VAD_MAX_SPEECH is the max chunk length fed to a single forward pass.
# Durations accept bare seconds (e.g. 600) or Go-style strings like 10m, 3h30m5s.
# TALKIES_MODEL_TTL=10m
# TALKIES_SWEEPER_INTERVAL=1m
# TALKIES_LOAD_TIMEOUT=5m
# TALKIES_MAX_UPLOAD_BYTES=104857600
# TALKIES_LOG_LEVEL=INFO
# TALKIES_PRELOAD=
# TALKIES_VAD_CHUNK_THRESHOLD=30
# TALKIES_VAD_MAX_SPEECH=28
# TALKIES_CUDA_MODEL_TTL=10m
# TALKIES_CUDA_SWEEPER_INTERVAL=1m
# TALKIES_CUDA_LOAD_TIMEOUT=5m
# TALKIES_CUDA_MAX_UPLOAD_BYTES=104857600
# TALKIES_CUDA_LOG_LEVEL=INFO
# TALKIES_CUDA_PRELOAD=
# TALKIES_CUDA_VAD_CHUNK_THRESHOLD=30
# TALKIES_CUDA_VAD_MAX_SPEECH=28

# vllm (CPU) / vllm-cuda — supervised single-model vLLM (lazy load +
# idle TTL unload). Models declared in vllm/models.cpu.json and
# vllm/models.cuda.json respectively. PRELOAD/PREFETCH are model_ids
# (slugs), not HF repos. VLLM_CPU_KVCACHE_SPACE is GB of RAM the CPU
# backend reserves for the KV cache.
# VLLM_MODEL_TTL=600
# VLLM_SWEEPER_INTERVAL=60
# VLLM_LOAD_TIMEOUT=600
# VLLM_REQUEST_TIMEOUT=300
# VLLM_LOG_LEVEL=INFO
# VLLM_PRELOAD=
# VLLM_PREFETCH=
# VLLM_CPU_KVCACHE_SPACE=4
# VLLM_CUDA_MODEL_TTL=600
# VLLM_CUDA_SWEEPER_INTERVAL=60
# VLLM_CUDA_LOAD_TIMEOUT=600
# VLLM_CUDA_REQUEST_TIMEOUT=300
# VLLM_CUDA_LOG_LEVEL=INFO
# VLLM_CUDA_PRELOAD=
# VLLM_CUDA_PREFETCH=

# Cloudflared — named tunnel docs: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/
# Without config/creds a random *.trycloudflare.com URL is assigned (no account needed)
CLOUDFLARED_CONFIG=
CLOUDFLARED_CREDS=
