# syntax=docker/dockerfile:1.7
#
# CUDA image — vLLM OpenAI server base + our Python wrapper (FastAPI).
#
# The wrapper supervises a single `vllm serve` subprocess at a time and
# proxies /v1/audio/transcriptions + /v1/chat/completions through to it.
# Audio decoding (ffmpeg, PyAV) happens inside vllm itself — the base
# image already ships ffmpeg and we layer the `vllm[audio]` extras on top.
#
# Models served from this image (selected per-request via the `model`
# field; only one is resident in VRAM at any moment):
#   - Qwen/Qwen3-ASR-1.7B
#   - mistralai/Voxtral-Mini-3B-2507

FROM vllm/vllm-openai:v0.21.0 AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    TZ=UTC \
    VLLM_WRAP_HOST=0.0.0.0 \
    VLLM_WRAP_PORT=8000 \
    VLLM_WRAP_SUBPROCESS_PORT=18000 \
    VLLM_WRAP_MODELS_FILE=/app/models.json \
    VLLM_WRAP_DATA_DIR=/data \
    HF_HOME=/data/hf \
    HF_HUB_OFFLINE=1 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    DEBIAN_FRONTEND=noninteractive

# vllm/vllm-openai's entrypoint runs as root and execs `vllm serve` directly.
# We need our own entrypoint + a non-root user, so reset both.
USER root

RUN (userdel -r ubuntu 2>/dev/null || true) \
    && useradd -u 1000 --create-home --shell /bin/bash vllmuser \
    && mkdir -p /data \
    && chown vllmuser:vllmuser /data

# Layer the audio extras on top of the base image (the official image ships
# vllm without `[audio]` — PyAV + soundfile + scipy + mistral_common[audio]
# are required for Voxtral/Qwen3-ASR).
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
        "av==13.1.0" \
        "soundfile==0.13.1" \
        "scipy==1.14.1" \
        "librosa==0.10.2" \
    && pip install \
        "fastapi==0.136.1" \
        "uvicorn==0.47.0" \
        "pydantic==2.13.4" \
        "python-multipart==0.0.20" \
        "httpx==0.28.1"

WORKDIR /app

COPY --chown=vllmuser:vllmuser src ./src
COPY --chown=vllmuser:vllmuser pyproject.toml ./
COPY --chown=vllmuser:vllmuser models.json /app/models.json
COPY --chown=vllmuser:vllmuser entrypoint.sh /usr/local/bin/vllm-entrypoint
RUN chmod +x /usr/local/bin/vllm-entrypoint \
    && pip install -e /app

USER vllmuser

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD python3 -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/healthz').status==200 else 1)" || exit 1

# Override the upstream ENTRYPOINT (which is `vllm serve`); we run the wrapper.
ENTRYPOINT ["/usr/local/bin/vllm-entrypoint"]
