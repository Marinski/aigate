# syntax=docker/dockerfile:1.7
#
# CPU image — llama.cpp's official server base + our Python wrapper (FastAPI).
#
# Mirrors Dockerfile.cuda but uses the CPU-only `:server` tag of the official
# upstream image. Same supervisor / lazy-load / idle-TTL / /api/ps surface as
# vllm-wrap — only the underlying inference engine differs.
#
# Why this exists: vllm-CPU has weak vision-VLM support; llama.cpp on CPU does
# vision (mmproj) just fine and is the only practical way to run Qwen3-VL-class
# document models (Surya OCR 2, etc.) on hosts without a GPU.

# Pinned by digest. Tag at build time: ghcr.io/ggml-org/llama.cpp:server (b9603).
# Rev: ba1df050f3dc7827fc64936b2e24fe499c9f74eb. ENTRYPOINT is /app/llama-server.
FROM ghcr.io/ggml-org/llama.cpp:server@sha256:7d02b045314fbc22f8cc763fa47fb5a9e8cbfb2c7b8204a87e94c109c0a9e874 AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    TZ=UTC \
    LLAMACPP_WRAP_HOST=0.0.0.0 \
    LLAMACPP_WRAP_PORT=8000 \
    LLAMACPP_WRAP_SUBPROCESS_PORT=18000 \
    LLAMACPP_WRAP_MODELS_FILE=/app/models.json \
    LLAMACPP_WRAP_DATA_DIR=/data \
    LLAMACPP_WRAP_DEVICE=cpu \
    LLAMACPP_WRAP_SERVER_BIN=/app/llama-server \
    HF_HOME=/data/hf \
    HF_HUB_OFFLINE=1 \
    DEBIAN_FRONTEND=noninteractive

# Upstream's ENTRYPOINT is `/app/llama-server` directly. We need our own
# entrypoint + a non-root user. Reset both.
USER root

# Wrapper deps. The base image is debian-slim with no Python preinstalled.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        ca-certificates \
        poppler-utils \
    && rm -rf /var/lib/apt/lists/*

RUN (userdel -r ubuntu 2>/dev/null || true) \
    && useradd -u 1000 --create-home --shell /bin/bash llamauser \
    && mkdir -p /data \
    && chown llamauser:llamauser /data

# Wrapper Python deps. Same pinned versions as vllm-wrap so the supervisor
# code surface is identical across both services.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --break-system-packages \
        "fastapi==0.136.1" \
        "uvicorn==0.47.0" \
        "pydantic==2.13.4" \
        "httpx==0.28.1"

WORKDIR /app

COPY --chown=llamauser:llamauser src ./src
COPY --chown=llamauser:llamauser pyproject.toml ./
COPY --chown=llamauser:llamauser models.cpu.json /app/models.json
COPY --chown=llamauser:llamauser entrypoint.sh /usr/local/bin/llamacpp-entrypoint
RUN chmod +x /usr/local/bin/llamacpp-entrypoint \
    && pip install --break-system-packages -e /app

USER llamauser

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD python3 -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://127.0.0.1:8000/healthz').status==200 else 1)" || exit 1

# Override the upstream ENTRYPOINT (which is `/app/llama-server`); we run the
# wrapper instead, and the wrapper spawns `llama-server` as a subprocess.
ENTRYPOINT ["/usr/local/bin/llamacpp-entrypoint"]
